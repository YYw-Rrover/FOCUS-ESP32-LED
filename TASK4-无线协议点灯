#define TAG "BLE_LED_DEMO"

/* LED PWM */
#define LED_GPIO          18
#define LEDC_SPEED_MODE   LEDC_LOW_SPEED_MODE
#define LEDC_TIMER        LEDC_TIMER_0
#define LEDC_CHANNEL      LEDC_CHANNEL_0
#define LEDC_RESOLUTION   LEDC_TIMER_13_BIT
#define LEDC_FREQ_HZ      5000
#define LEDC_MAX_DUTY     ((1 << 13) - 1)

/* 自定义 UUID：服务 FFF0，特征 FFF1 */
static const ble_uuid16_t gatt_svc_uuid = BLE_UUID16_INIT(0xFFF0);
static const ble_uuid16_t gatt_chr_uuid = BLE_UUID16_INIT(0xFFF1);

static uint8_t own_addr_type;

/* ---------- LED ---------- */

typedef enum {
    LED_MODE_OFF = 0,
    LED_MODE_ON,
    LED_MODE_BREATH,
    LED_MODE_LEVEL
} led_mode_t;

static struct {
    led_mode_t mode;
    uint32_t duty;
} g_led = {
    .mode = LED_MODE_OFF,
    .duty = 0,
};

static void ledc_init_simple(void)
{
    ledc_timer_config_t timer_cfg = {
        .speed_mode      = LEDC_SPEED_MODE,
        .timer_num       = LEDC_TIMER,
        .duty_resolution = LEDC_RESOLUTION,
        .freq_hz         = LEDC_FREQ_HZ,
        .clk_cfg         = LEDC_AUTO_CLK,
    };
    ESP_ERROR_CHECK(ledc_timer_config(&timer_cfg));

    ledc_channel_config_t channel_cfg = {
        .gpio_num   = LED_GPIO,
        .speed_mode = LEDC_SPEED_MODE,
        .channel    = LEDC_CHANNEL,
        .timer_sel  = LEDC_TIMER,
        .duty       = 0,
        .hpoint     = 0,
    };
    ESP_ERROR_CHECK(ledc_channel_config(&channel_cfg));
}

static void led_apply_duty(uint32_t duty)
{
    if (duty > LEDC_MAX_DUTY) {
        duty = LEDC_MAX_DUTY;
    }
    ESP_ERROR_CHECK(ledc_set_duty(LEDC_SPEED_MODE, LEDC_CHANNEL, duty));
    ESP_ERROR_CHECK(ledc_update_duty(LEDC_SPEED_MODE, LEDC_CHANNEL));
    g_led.duty = duty;
}

static void led_set_mode(led_mode_t mode, uint32_t value)
{
    g_led.mode = mode;

    switch (mode) {
        case LED_MODE_OFF:
            led_apply_duty(0);
            ESP_LOGI(TAG, "LED -> OFF");
            break;
        case LED_MODE_ON:
            led_apply_duty(LEDC_MAX_DUTY);
            ESP_LOGI(TAG, "LED -> ON");
            break;
        case LED_MODE_LEVEL:
            led_apply_duty(value);
            ESP_LOGI(TAG, "LED -> LEVEL=%" PRIu32, value);
            break;
        case LED_MODE_BREATH:
            ESP_LOGI(TAG, "LED -> BREATH");
            break;
        default:
            break;
    }
}

static void process_line(const char *line)
{
    if (strcmp(line, "on") == 0) {
        led_set_mode(LED_MODE_ON, 0);

    } else if (strcmp(line, "off") == 0) {
        led_set_mode(LED_MODE_OFF, 0);

    } else if (strcmp(line, "breath") == 0) {
        led_set_mode(LED_MODE_BREATH, 0);

    } else if (strncmp(line, "set:", 4) == 0) {
        int val = atoi(line + 4);
        if (val < 0) val = 0;
        if (val > LEDC_MAX_DUTY) val = LEDC_MAX_DUTY;
        led_set_mode(LED_MODE_LEVEL, (uint32_t)val);

    } else if (line[0] == '+') {
        int delta = atoi(line + 1);
        if (delta < 0) delta = 0;

        int32_t new_duty = (int32_t)g_led.duty + delta;
        if (new_duty > LEDC_MAX_DUTY) new_duty = LEDC_MAX_DUTY;

        led_set_mode(LED_MODE_LEVEL, (uint32_t)new_duty);

    } else if (line[0] == '-') {
        int delta = atoi(line + 1);
        if (delta < 0) delta = 0;

        int32_t new_duty = (int32_t)g_led.duty - delta;
        if (new_duty < 0) new_duty = 0;

        led_set_mode(LED_MODE_LEVEL, (uint32_t)new_duty);

    } else {
        ESP_LOGW(TAG, "Unknown cmd: %s", line);
    }
}

static void breath_task(void *arg)
{
    int duty = 0;
    int step = 60;

    while (1) {
        if (g_led.mode == LED_MODE_BREATH) {
            led_apply_duty((uint32_t)duty);
            duty += step;

            if (duty >= LEDC_MAX_DUTY) {
                duty = LEDC_MAX_DUTY;
                step = -60;
            } else if (duty <= 0) {
                duty = 0;
                step = 60;
            }
        } else {
            duty = (int)g_led.duty;
            if (duty >= LEDC_MAX_DUTY) step = -60;
            if (duty <= 0) step = 60;
        }
        vTaskDelay(pdMS_TO_TICKS(20));
    }
}

/* ---------- BLE ---------- */

static int ble_chr_access_cb(uint16_t conn_handle,
                             uint16_t attr_handle,
                             struct ble_gatt_access_ctxt *ctxt,
                             void *arg)
{
    if (ctxt->op == BLE_GATT_ACCESS_OP_WRITE_CHR) {
        char buf[64] = {0};
        uint16_t len = OS_MBUF_PKTLEN(ctxt->om);

        if (len >= sizeof(buf)) {
            len = sizeof(buf) - 1;
        }

        int rc = ble_hs_mbuf_to_flat(ctxt->om, buf, len, NULL);
        if (rc != 0) {
            return BLE_ATT_ERR_UNLIKELY;
        }

        buf[len] = '\0';
        ESP_LOGI(TAG, "BLE RX: %s", buf);
        process_line(buf);
        return 0;
    }

    return BLE_ATT_ERR_UNLIKELY;
}

static const struct ble_gatt_svc_def gatt_svcs[] = {
    {
        .type = BLE_GATT_SVC_TYPE_PRIMARY,
        .uuid = &gatt_svc_uuid.u,
        .characteristics = (struct ble_gatt_chr_def[]) {
            {
                .uuid = &gatt_chr_uuid.u,
                .access_cb = ble_chr_access_cb,
                .flags = BLE_GATT_CHR_F_WRITE | BLE_GATT_CHR_F_WRITE_NO_RSP,
            },
            {0}
        },
    },
    {0}
};

static void ble_app_advertise(void);

static int ble_gap_event_cb(struct ble_gap_event *event, void *arg)
{
    switch (event->type) {
        case BLE_GAP_EVENT_CONNECT:
            if (event->connect.status == 0) {
                ESP_LOGI(TAG, "BLE connected");
            } else {
                ESP_LOGI(TAG, "BLE connect failed, restart adv");
                ble_app_advertise();
            }
            return 0;

        case BLE_GAP_EVENT_DISCONNECT:
            ESP_LOGI(TAG, "BLE disconnected, restart adv");
            ble_app_advertise();
            return 0;

        case BLE_GAP_EVENT_ADV_COMPLETE:
            ESP_LOGI(TAG, "BLE adv complete, restart adv");
            ble_app_advertise();
            return 0;

        default:
            return 0;
    }
}

static void ble_app_advertise(void)
{
    struct ble_gap_adv_params adv_params;
    struct ble_hs_adv_fields fields;

    memset(&fields, 0, sizeof(fields));
    fields.flags = BLE_HS_ADV_F_DISC_GEN | BLE_HS_ADV_F_BREDR_UNSUP;

    const char *name = "FOCUS_LED";
    fields.name = (const uint8_t *)name;
    fields.name_len = strlen(name);
    fields.name_is_complete = 1;

    int rc = ble_gap_adv_set_fields(&fields);
    if (rc != 0) {
        ESP_LOGE(TAG, "ble_gap_adv_set_fields rc=%d", rc);
        return;
    }

    memset(&adv_params, 0, sizeof(adv_params));
    adv_params.conn_mode = BLE_GAP_CONN_MODE_UND;
    adv_params.disc_mode = BLE_GAP_DISC_MODE_GEN;

    rc = ble_gap_adv_start(own_addr_type, NULL, BLE_HS_FOREVER,
                           &adv_params, ble_gap_event_cb, NULL);
    if (rc != 0) {
        ESP_LOGE(TAG, "ble_gap_adv_start rc=%d", rc);
    } else {
        ESP_LOGI(TAG, "BLE advertising as FOCUS_LED");
    }
}

static void ble_app_on_sync(void)
{
    int rc = ble_hs_id_infer_auto(0, &own_addr_type);
    if (rc != 0) {
        ESP_LOGE(TAG, "ble_hs_id_infer_auto rc=%d", rc);
        return;
    }

    ble_app_advertise();
}

static void host_task(void *param)
{
    nimble_port_run();
    nimble_port_freertos_deinit();
}

void app_main(void)
{
    esp_err_t ret = nvs_flash_init();
    if (ret == ESP_ERR_NVS_NO_FREE_PAGES || ret == ESP_ERR_NVS_NEW_VERSION_FOUND) {
        ESP_ERROR_CHECK(nvs_flash_erase());
        ret = nvs_flash_init();
    }
    ESP_ERROR_CHECK(ret);

    ledc_init_simple();
    led_set_mode(LED_MODE_OFF, 0);

    xTaskCreate(breath_task, "breath_task", 2048, NULL, 4, NULL);

    ESP_ERROR_CHECK(nimble_port_init());

    ble_svc_gap_init();
    ble_svc_gatt_init();

    int rc = ble_gatts_count_cfg(gatt_svcs);
    assert(rc == 0);
    rc = ble_gatts_add_svcs(gatt_svcs);
    assert(rc == 0);

    ble_hs_cfg.sync_cb = ble_app_on_sync;

    nimble_port_freertos_init(host_task);
}
