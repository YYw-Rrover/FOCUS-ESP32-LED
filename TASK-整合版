/* =========================
 * 1. LED 配置
 * ========================= */
#define LED_GPIO                18
#define LEDC_SPEED_MODE         LEDC_LOW_SPEED_MODE
#define LEDC_TIMER              LEDC_TIMER_0
#define LEDC_CHANNEL            LEDC_CHANNEL_0
#define LEDC_RESOLUTION         LEDC_TIMER_13_BIT
#define LEDC_FREQ_HZ            5000
#define LEDC_MAX_DUTY           ((1 << 13) - 1)

/* =========================
 * 2. BLE 配置
 * ========================= */
static const ble_uuid16_t gatt_svc_uuid = BLE_UUID16_INIT(0xFFF0);
static const ble_uuid16_t gatt_chr_uuid = BLE_UUID16_INIT(0xFFF1);
static uint8_t own_addr_type;

/* =========================
 * 3. INMP441 配置
 * ========================= */
#define I2S_BCLK_GPIO           4   // SCK
#define I2S_WS_GPIO             5   // WS
#define I2S_DIN_GPIO            6   // SD

#define SAMPLE_RATE             16000
#define FRAME_SAMPLES           256

/* =========================
 * 4. Task6 低频检测参数
 * ========================= */
#define LOW_BIN_START           2
#define LOW_BIN_END             4
#define LOW_FREQ_THRESHOLD      8.0e10f
#define TRIGGER_COUNT_NEEDED    4
#define TRIGGER_COOLDOWN_MS     2500
#define STARTUP_IGNORE_MS       3000
#define BLINK_DURATION_MS       4000

static i2s_chan_handle_t rx_chan;

/* =========================
 * 5. LED 模式定义（底层执行）
 * ========================= */
typedef enum {
    LED_MODE_OFF = 0,
    LED_MODE_ON,
    LED_MODE_BREATH,
    LED_MODE_LEVEL,
    LED_MODE_BLINK
} led_mode_t;

/* LED 底层状态 */
static struct {
    led_mode_t mode;
    uint32_t duty;
} g_led = {
    .mode = LED_MODE_OFF,
    .duty = 0,
};

/* =========================
 * 6. Task5 状态机定义
 * ========================= */
typedef enum {
    LIGHT_STATE_OFF = 0,
    LIGHT_STATE_ON,
    LIGHT_STATE_BREATH,
    LIGHT_STATE_LEVEL,
    LIGHT_STATE_BLINK
} light_state_t;

typedef enum {
    LIGHT_EVT_ON = 0,
    LIGHT_EVT_OFF,
    LIGHT_EVT_BREATH,
    LIGHT_EVT_BLINK,
    LIGHT_EVT_SET_LEVEL,
    LIGHT_EVT_INC_LEVEL,
    LIGHT_EVT_DEC_LEVEL,
    LIGHT_EVT_AUDIO_TRIGGER
} light_event_t;

/* 状态机上下文 */
static struct {
    light_state_t state;
    uint32_t duty;
    int64_t blink_start_ms;
} g_light = {
    .state = LIGHT_STATE_OFF,
    .duty = 0,
    .blink_start_ms = 0,
};

/* =========================
 * 7. LED 底层控制
 * ========================= */
static void ledc_init_simple(void)
{
    ledc_timer_config_t timer_cfg = {
        .speed_mode      = LEDC_SPEED_MODE,
        .timer_num       = LEDC_TIMER,
        .duty_resolution = LEDC_RESOLUTION,
        .freq_hz         = LEDC_FREQ_HZ,
        .clk_cfg         = LEDC_AUTO_CLK,
    };

    ESP_ERROR_CHECK(ledc_timer_config(&timer_cfg));

    ledc_channel_config_t channel_cfg = {
        .gpio_num   = LED_GPIO,
        .speed_mode = LEDC_SPEED_MODE,
        .channel    = LEDC_CHANNEL,
        .timer_sel  = LEDC_TIMER,
        .duty       = 0,
        .hpoint     = 0,
    };

    ESP_ERROR_CHECK(ledc_channel_config(&channel_cfg));
    ESP_LOGI(TAG, "LEDC init done");
}

static void led_apply_duty(uint32_t duty)
{
    if (duty > LEDC_MAX_DUTY) {
        duty = LEDC_MAX_DUTY;
    }

    ESP_ERROR_CHECK(ledc_set_duty(LEDC_SPEED_MODE, LEDC_CHANNEL, duty));
    ESP_ERROR_CHECK(ledc_update_duty(LEDC_SPEED_MODE, LEDC_CHANNEL));
    g_led.duty = duty;
}

static void led_set_mode(led_mode_t mode, uint32_t value)
{
    g_led.mode = mode;

    switch (mode) {
        case LED_MODE_OFF:
            led_apply_duty(0);
            ESP_LOGI(TAG, "LED -> OFF");
            break;

        case LED_MODE_ON:
            led_apply_duty(LEDC_MAX_DUTY);
            ESP_LOGI(TAG, "LED -> ON");
            break;

        case LED_MODE_LEVEL:
            led_apply_duty(value);
            ESP_LOGI(TAG, "LED -> LEVEL=%" PRIu32, value);
            break;

        case LED_MODE_BREATH:
            ESP_LOGI(TAG, "LED -> BREATH");
            break;

        case LED_MODE_BLINK:
            ESP_LOGI(TAG, "LED -> BLINK");
            break;

        default:
            break;
    }
}

/* =========================
 * 8. Task5 状态机核心
 * ========================= */
static void light_fsm_handle(light_event_t evt, int value)
{
    int64_t now_ms = esp_timer_get_time() / 1000;

    switch (evt) {
        case LIGHT_EVT_ON:
            g_light.state = LIGHT_STATE_ON;
            g_light.duty = LEDC_MAX_DUTY;
            led_set_mode(LED_MODE_ON, 0);
            break;

        case LIGHT_EVT_OFF:
            g_light.state = LIGHT_STATE_OFF;
            g_light.duty = 0;
            led_set_mode(LED_MODE_OFF, 0);
            break;

        case LIGHT_EVT_BREATH:
            g_light.state = LIGHT_STATE_BREATH;
            led_set_mode(LED_MODE_BREATH, 0);
            break;

        case LIGHT_EVT_BLINK:
            g_light.state = LIGHT_STATE_BLINK;
            g_light.blink_start_ms = now_ms;
            led_set_mode(LED_MODE_BLINK, 0);
            break;

        case LIGHT_EVT_SET_LEVEL:
            if (value < 0) value = 0;
            if (value > LEDC_MAX_DUTY) value = LEDC_MAX_DUTY;
            g_light.state = LIGHT_STATE_LEVEL;
            g_light.duty = (uint32_t)value;
            led_set_mode(LED_MODE_LEVEL, (uint32_t)value);
            break;

        case LIGHT_EVT_INC_LEVEL: {
            int32_t new_duty = (int32_t)g_light.duty + value;
            if (new_duty > LEDC_MAX_DUTY) new_duty = LEDC_MAX_DUTY;
            g_light.state = LIGHT_STATE_LEVEL;
            g_light.duty = (uint32_t)new_duty;
            led_set_mode(LED_MODE_LEVEL, (uint32_t)new_duty);
            break;
        }

        case LIGHT_EVT_DEC_LEVEL: {
            int32_t new_duty = (int32_t)g_light.duty - value;
            if (new_duty < 0) new_duty = 0;
            g_light.state = LIGHT_STATE_LEVEL;
            g_light.duty = (uint32_t)new_duty;
            led_set_mode(LED_MODE_LEVEL, (uint32_t)new_duty);
            break;
        }

        case LIGHT_EVT_AUDIO_TRIGGER:
            /* Task6：声音检测到后，统一交给状态机处理 */
            g_light.state = LIGHT_STATE_BLINK;
            g_light.blink_start_ms = now_ms;
            led_set_mode(LED_MODE_BLINK, 0);
            break;

        default:
            break;
    }
}

/* =========================
 * 9. 命令解析（BLE 输入模块 -> 状态机）
 * ========================= */
static void process_line(const char *line)
{
    if (strcmp(line, "on") == 0) {
        light_fsm_handle(LIGHT_EVT_ON, 0);

    } else if (strcmp(line, "off") == 0) {
        light_fsm_handle(LIGHT_EVT_OFF, 0);

    } else if (strcmp(line, "breath") == 0) {
        light_fsm_handle(LIGHT_EVT_BREATH, 0);

    } else if (strcmp(line, "blink") == 0) {
        light_fsm_handle(LIGHT_EVT_BLINK, 0);

    } else if (strncmp(line, "set:", 4) == 0) {
        int val = atoi(line + 4);
        light_fsm_handle(LIGHT_EVT_SET_LEVEL, val);

    } else if (line[0] == '+') {
        int delta = atoi(line + 1);
        if (delta < 0) delta = 0;
        light_fsm_handle(LIGHT_EVT_INC_LEVEL, delta);

    } else if (line[0] == '-') {
        int delta = atoi(line + 1);
        if (delta < 0) delta = 0;
        light_fsm_handle(LIGHT_EVT_DEC_LEVEL, delta);

    } else {
        ESP_LOGW(TAG, "Unknown cmd: %s", line);
    }
}

/* =========================
 * 10. LED 灯效任务（多线程）
 * ========================= */
static void effect_task(void *arg)
{
    int duty = 0;
    int step = 60;
    bool blink_on = false;

    while (1) {
        int64_t now_ms = esp_timer_get_time() / 1000;

        if (g_light.state == LIGHT_STATE_BLINK) {
            /* 闪烁 4 秒后自动关闭 */
            if ((now_ms - g_light.blink_start_ms) > BLINK_DURATION_MS) {
                light_fsm_handle(LIGHT_EVT_OFF, 0);
                vTaskDelay(pdMS_TO_TICKS(50));
                continue;
            }

            led_apply_duty(blink_on ? 0 : LEDC_MAX_DUTY);
            blink_on = !blink_on;
            vTaskDelay(pdMS_TO_TICKS(300));

        } else if (g_light.state == LIGHT_STATE_BREATH) {
            led_apply_duty((uint32_t)duty);
            duty += step;

            if (duty >= LEDC_MAX_DUTY) {
                duty = LEDC_MAX_DUTY;
                step = -60;
            } else if (duty <= 0) {
                duty = 0;
                step = 60;
            }

            blink_on = false;
            vTaskDelay(pdMS_TO_TICKS(20));

        } else {
            duty = (int)g_led.duty;
            if (duty >= LEDC_MAX_DUTY) step = -60;
            if (duty <= 0) step = 60;
            blink_on = false;
            vTaskDelay(pdMS_TO_TICKS(50));
        }
    }
}

/* =========================
 * 11. BLE 输入模块
 * ========================= */
static int ble_chr_access_cb(uint16_t conn_handle,
                             uint16_t attr_handle,
                             struct ble_gatt_access_ctxt *ctxt,
                             void *arg)
{
    if (ctxt->op == BLE_GATT_ACCESS_OP_WRITE_CHR) {
        char buf[64] = {0};
        uint16_t len = OS_MBUF_PKTLEN(ctxt->om);

        if (len >= sizeof(buf)) {
            len = sizeof(buf) - 1;
        }

        int rc = ble_hs_mbuf_to_flat(ctxt->om, buf, len, NULL);
        if (rc != 0) {
            return BLE_ATT_ERR_UNLIKELY;
        }

        buf[len] = '\0';
        ESP_LOGI(TAG, "BLE RX: %s", buf);
        process_line(buf);
        return 0;
    }

    return BLE_ATT_ERR_UNLIKELY;
}

static const struct ble_gatt_svc_def gatt_svcs[] = {
    {
        .type = BLE_GATT_SVC_TYPE_PRIMARY,
        .uuid = &gatt_svc_uuid.u,
        .characteristics = (struct ble_gatt_chr_def[]) {
            {
                .uuid = &gatt_chr_uuid.u,
                .access_cb = ble_chr_access_cb,
                .flags = BLE_GATT_CHR_F_WRITE | BLE_GATT_CHR_F_WRITE_NO_RSP,
            },
            {0}
        },
    },
    {0}
};

static void ble_app_advertise(void);

static int ble_gap_event_cb(struct ble_gap_event *event, void *arg)
{
    switch (event->type) {
        case BLE_GAP_EVENT_CONNECT:
            if (event->connect.status == 0) {
                ESP_LOGI(TAG, "BLE connected");
            } else {
                ESP_LOGI(TAG, "BLE connect failed, restart adv");
                ble_app_advertise();
            }
            return 0;

        case BLE_GAP_EVENT_DISCONNECT:
            ESP_LOGI(TAG, "BLE disconnected, restart adv");
            ble_app_advertise();
            return 0;

        case BLE_GAP_EVENT_ADV_COMPLETE:
            ESP_LOGI(TAG, "BLE adv complete, restart adv");
            ble_app_advertise();
            return 0;

        default:
            return 0;
    }
}

static void ble_app_advertise(void)
{
    struct ble_gap_adv_params adv_params;
    struct ble_hs_adv_fields fields;

    memset(&fields, 0, sizeof(fields));
    fields.flags = BLE_HS_ADV_F_DISC_GEN | BLE_HS_ADV_F_BREDR_UNSUP;

    const char *name = "FOCUS_LED";
    fields.name = (const uint8_t *)name;
    fields.name_len = strlen(name);
    fields.name_is_complete = 1;

    int rc = ble_gap_adv_set_fields(&fields);
    if (rc != 0) {
        ESP_LOGE(TAG, "ble_gap_adv_set_fields rc=%d", rc);
        return;
    }

    memset(&adv_params, 0, sizeof(adv_params));
    adv_params.conn_mode = BLE_GAP_CONN_MODE_UND;
    adv_params.disc_mode = BLE_GAP_DISC_MODE_GEN;

    rc = ble_gap_adv_start(own_addr_type, NULL, BLE_HS_FOREVER,
                           &adv_params, ble_gap_event_cb, NULL);
    if (rc != 0) {
        ESP_LOGE(TAG, "ble_gap_adv_start rc=%d", rc);
    } else {
        ESP_LOGI(TAG, "BLE advertising as FOCUS_LED");
    }
}

static void ble_app_on_sync(void)
{
    int rc = ble_hs_id_infer_auto(0, &own_addr_type);
    if (rc != 0) {
        ESP_LOGE(TAG, "ble_hs_id_infer_auto rc=%d", rc);
        return;
    }

    ble_app_advertise();
}

static void host_task(void *param)
{
    nimble_port_run();
    nimble_port_freertos_deinit();
}

/* =========================
 * 12. I2S 麦克风初始化
 * ========================= */
static void i2s_mic_init(void)
{
    i2s_chan_config_t chan_cfg = I2S_CHANNEL_DEFAULT_CONFIG(I2S_NUM_0, I2S_ROLE_MASTER);
    chan_cfg.auto_clear = true;
    ESP_ERROR_CHECK(i2s_new_channel(&chan_cfg, NULL, &rx_chan));

    i2s_std_config_t std_cfg = {
        .clk_cfg = I2S_STD_CLK_DEFAULT_CONFIG(SAMPLE_RATE),
        .slot_cfg = (i2s_std_slot_config_t) {
            .data_bit_width = I2S_DATA_BIT_WIDTH_32BIT,
            .slot_bit_width = I2S_SLOT_BIT_WIDTH_32BIT,
            .slot_mode = I2S_SLOT_MODE_MONO,
            .slot_mask = I2S_STD_SLOT_LEFT,
            .ws_width = 32,
            .ws_pol = false,
            .bit_shift = true,
        },
        .gpio_cfg = {
            .mclk = I2S_GPIO_UNUSED,
            .bclk = I2S_BCLK_GPIO,
            .ws   = I2S_WS_GPIO,
            .dout = I2S_GPIO_UNUSED,
            .din  = I2S_DIN_GPIO,
            .invert_flags = {
                .mclk_inv = false,
                .bclk_inv = false,
                .ws_inv   = false,
            },
        },
    };

    ESP_ERROR_CHECK(i2s_channel_init_std_mode(rx_chan, &std_cfg));
    ESP_ERROR_CHECK(i2s_channel_enable(rx_chan));

    ESP_LOGI(TAG, "I2S mic init done");
}

/* =========================
 * 13. Task6 频域分析
 * ========================= */
static void remove_dc_and_convert(const int32_t *in, float *out, int n)
{
    double mean = 0.0;

    for (int i = 0; i < n; i++) {
        mean += (double)(in[i] >> 8);
    }
    mean /= n;

    for (int i = 0; i < n; i++) {
        out[i] = (float)((in[i] >> 8) - mean);
    }
}

static float calc_low_freq_energy(const float *x, int n)
{
    float total_energy = 0.0f;

    for (int k = LOW_BIN_START; k <= LOW_BIN_END; k++) {
        float real = 0.0f;
        float imag = 0.0f;

        for (int t = 0; t < n; t++) {
            float angle = 2.0f * (float)M_PI * k * t / n;
            real += x[t] * cosf(angle);
            imag -= x[t] * sinf(angle);
        }

        float power = real * real + imag * imag;
        total_energy += power;
    }

    return total_energy;
}

/* =========================
 * 14. 音频检测任务（多线程）
 * ========================= */
static void audio_task(void *arg)
{
    int32_t samples[FRAME_SAMPLES];
    float fft_in[FRAME_SAMPLES];
    size_t bytes_read = 0;

    int64_t start_time_ms = esp_timer_get_time() / 1000;
    int64_t last_trigger_time = 0;
    int high_count = 0;

    while (1) {
        esp_err_t ret = i2s_channel_read(
            rx_chan,
            samples,
            sizeof(samples),
            &bytes_read,
            pdMS_TO_TICKS(1000)
        );

        if (ret == ESP_OK && bytes_read > 0) {
            int sample_count = bytes_read / sizeof(int32_t);

            remove_dc_and_convert(samples, fft_in, sample_count);
            float low_energy = calc_low_freq_energy(fft_in, sample_count);
            int64_t now_ms = esp_timer_get_time() / 1000;

            ESP_LOGI(TAG, "low_energy=%.2f", low_energy);

            /* 上电前几秒忽略 */
            if ((now_ms - start_time_ms) < STARTUP_IGNORE_MS) {
                vTaskDelay(pdMS_TO_TICKS(50));
                continue;
            }

            if (low_energy > LOW_FREQ_THRESHOLD) {
                high_count++;
            } else {
                high_count = 0;
            }

            /* Task6 检测结果 -> 状态机事件 */
            if (g_light.state != LIGHT_STATE_BLINK &&
                high_count >= TRIGGER_COUNT_NEEDED &&
                (now_ms - last_trigger_time) > TRIGGER_COOLDOWN_MS) {

                ESP_LOGI(TAG, "Low frequency detected! -> FSM AUDIO_TRIGGER");
                light_fsm_handle(LIGHT_EVT_AUDIO_TRIGGER, 0);
                last_trigger_time = now_ms;
                high_count = 0;
            }

        } else {
            ESP_LOGW(TAG, "i2s read timeout or error");
        }

        vTaskDelay(pdMS_TO_TICKS(50));
    }
}

/* =========================
 * 15. 主函数
 * ========================= */
void app_main(void)
{
    ESP_LOGI(TAG, "===== NOW RUNNING: FINAL TASK5+TASK6 VERSION =====");

    esp_err_t ret = nvs_flash_init();
    if (ret == ESP_ERR_NVS_NO_FREE_PAGES || ret == ESP_ERR_NVS_NEW_VERSION_FOUND) {
        ESP_ERROR_CHECK(nvs_flash_erase());
        ret = nvs_flash_init();
    }
    ESP_ERROR_CHECK(ret);

    ledc_init_simple();
    i2s_mic_init();

    /* 用状态机初始化默认状态 */
    light_fsm_handle(LIGHT_EVT_OFF, 0);

    /* 多线程：灯效任务 */
    xTaskCreate(effect_task, "effect_task", 3072, NULL, 4, NULL);

    /* 多线程：音频检测任务 */
    xTaskCreate(audio_task, "audio_task", 6144, NULL, 5, NULL);

    /* BLE 初始化 */
    ESP_ERROR_CHECK(nimble_port_init());

    ble_svc_gap_init();
    ble_svc_gatt_init();

    int rc = ble_gatts_count_cfg(gatt_svcs);
    assert(rc == 0);
    rc = ble_gatts_add_svcs(gatt_svcs);
    assert(rc == 0);

    ble_hs_cfg.sync_cb = ble_app_on_sync;

    /* 多线程：BLE 主机线程 */
    nimble_port_freertos_init(host_task);
}
